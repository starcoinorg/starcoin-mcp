{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starcoin.dev/schemas/unsigned-transaction-envelope.schema.json",
  "title": "UnsignedTransactionEnvelope",
  "type": "object",
  "required": [
    "transaction_kind",
    "raw_txn_bcs_hex",
    "transaction_summary",
    "chain_context",
    "prepared_at",
    "simulation_status",
    "execution_facts",
    "next_action"
  ],
  "properties": {
    "transaction_kind": {
      "type": "string",
      "enum": [
        "transfer",
        "contract_call",
        "publish_package",
        "unknown"
      ]
    },
    "raw_txn_bcs_hex": {
      "type": "string"
    },
    "raw_txn": {
      "type": "object"
    },
    "transaction_summary": {
      "type": "object"
    },
    "chain_context": {
      "type": "object",
      "required": [
        "chain_id",
        "network",
        "genesis_hash",
        "head_block_hash",
        "head_block_number",
        "observed_at"
      ],
      "properties": {
        "chain_id": {
          "type": [
            "integer",
            "string"
          ]
        },
        "network": {
          "type": "string"
        },
        "genesis_hash": {
          "type": "string"
        },
        "head_block_hash": {
          "type": "string"
        },
        "head_block_number": {
          "type": "integer"
        },
        "head_state_root": {
          "type": "string"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "prepared_at": {
      "type": "string",
      "format": "date-time"
    },
    "sequence_number_source": {
      "type": "string"
    },
    "gas_unit_price_source": {
      "type": "string"
    },
    "simulation_status": {
      "type": "string",
      "enum": [
        "performed",
        "skipped_missing_public_key",
        "skipped_by_policy",
        "failed"
      ]
    },
    "simulation": {
      "type": [
        "object",
        "null"
      ]
    },
    "execution_facts": {
      "type": "object",
      "required": [
        "sender",
        "sequence_number",
        "max_gas_amount",
        "gas_unit_price",
        "gas_token_code",
        "expiration_timestamp_secs",
        "chain_id",
        "estimated_max_network_fee"
      ],
      "properties": {
        "sender": {
          "type": "string"
        },
        "sequence_number": {
          "type": "integer"
        },
        "max_gas_amount": {
          "type": "integer"
        },
        "gas_unit_price": {
          "type": "integer"
        },
        "gas_token_code": {
          "type": "string"
        },
        "expiration_timestamp_secs": {
          "type": "integer"
        },
        "chain_id": {
          "type": "integer"
        },
        "estimated_max_network_fee": {
          "type": "string"
        },
        "estimated_network_fee": {
          "type": "string"
        },
        "transfer_receiver": {
          "type": "string"
        },
        "transfer_amount": {
          "type": "string"
        },
        "transfer_token_code": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "next_action": {
      "type": "string",
      "enum": [
        "sign_transaction",
        "get_public_key_then_simulate_or_sign",
        "simulate_then_sign"
      ]
    }
  },
  "additionalProperties": true
}
