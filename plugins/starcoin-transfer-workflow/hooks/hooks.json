{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "plugin_root=\"${STARCOIN_TRANSFER_PLUGIN_ROOT:-$HOME/plugins/starcoin-transfer-workflow}\"; if [ ! -f \"$plugin_root/scripts/doctor.py\" ]; then plugin_root=\"./plugins/starcoin-transfer-workflow\"; fi; python3 \"$plugin_root/scripts/doctor.py\" --session-start || true"
          }
        ]
      }
    ]
  }
}
